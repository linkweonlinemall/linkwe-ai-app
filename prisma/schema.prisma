  tags                String[]

  pricePerNight       Float
  weeklyRate          Float?
  monthlyRate         Float?
  cleaningFee         Float?
  securityDeposit     Float?

  bedrooms            Int?
  bathrooms           Int?
  maxGuests           Int
  minimumStay         Int?
  amenities           String[]

  checkInTime         String?
  checkOutTime        String?
  availableFrom       DateTime?

  cancellationPolicy  CancellationPolicy?
  instantBook         Boolean               @default(false)
  breakfastIncluded   Boolean               @default(false)
  petsAllowed         Boolean               @default(false)
  smokingAllowed      Boolean               @default(false)
  childrenAllowed     Boolean               @default(true)
  poolAccess          Boolean               @default(false)
  parkingAvailable    Boolean               @default(false)

  images              String[]
  latitude            Float
  longitude           Float
  address             String
  region              String
  website             String?
  phone               String?
  socialLinks         Json?
  rating              Float?

  isPublished         Boolean               @default(false)
  isFeatured          Boolean               @default(false)
  viewCount           Int                   @default(0)
  metaTitle           String?
  metaDescription     String?

  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([storeId])
  @@index([isPublished])
  @@index([type])
  @@index([region])
}

model Service {
  id                      String            @id @default(cuid())
  storeId                 String
  store                   Store             @relation(fields: [storeId], references: [id])
  title                   String
  slug                    String            @unique
  description             String?
  category                String?
  tags                    String[]

  priceType               ServicePriceType
  price                   Float?
  duration                Int?

  isBookable              Boolean           @default(false)
  availableDays           String[]
  availableHours          String?
  responseTime            String?

  onlineSessionAvailable  Boolean           @default(false)
  travelFee               Float?
  serviceArea             String[]

  experience              Int?
  qualifications          String[]
  languages               String[]
  portfolio               String[]

  latitude                Float?
  longitude               Float?
  address                 String?
  region                  String?

  rating                  Float?
  isPublished             Boolean           @default(false)
  isFeatured              Boolean           @default(false)
  viewCount               Int               @default(0)
  metaTitle               String?
  metaDescription         String?

  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  @@index([storeId])
  @@index([isPublished])
  @@index([region])
}

model StoreContentRelationship {
  id                  String              @id @default(cuid())
  requestingStoreId   String
  requestingStore     Store               @relation("RequestingStore", fields: [requestingStoreId], references: [id])
  targetStoreId       String
  targetStore         Store               @relation("TargetStore", fields: [targetStoreId], references: [id])
  contentType         String
  contentId           String
  status              RelationshipStatus  @default(PENDING)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([requestingStoreId, targetStoreId, contentType, contentId])
  @@index([requestingStoreId])
  @@index([targetStoreId])
  @@index([status])
}
