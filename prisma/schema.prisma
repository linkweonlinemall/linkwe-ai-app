model Product {
  id                    String            @id @default(cuid())
  storeId               String
  store                 Store             @relation(fields: [storeId], references: [id])

  name                  String
  slug                  String            @unique
  description           String?
  shortDescription      String?
  deliveryFee           Float?
  deliveryRegions       String[]          @default([])
  price                 Float
  compareAtPrice        Float?
  sku                   String?
  stock                 Int?
  condition             ProductCondition?
  brand                 String?
  category              String?
  tags                  String[]
  images                String[]

  weight                Float?
  weightUnit            WeightUnit?
  length                Float?
  width                 Float?
  height                Float?
  allowPickup           Boolean           @default(false)
  allowDelivery         Boolean           @default(false)
  returnPolicy          String?

  isDigital             Boolean           @default(false)
  digitalFileUrl        String?
  fileType              String?
  fileSizeKb            Int?
  downloadLimit         Int?
  downloadExpiryDays    Int?
  previewUrl            String?
  licenceType           LicenceType?

  isBookable            Boolean           @default(false)
  bookingType           BookingType?
  sessionDuration       Int?
  advanceBookingDays    Int?
  cancellationHours     Int?
  maxGroupSize          Int?
  requiresApproval      Boolean           @default(false)

  latitude              Float?
  longitude             Float?
  address               String?

  isPublished           Boolean           @default(false)
  isFeatured            Boolean           @default(false)
  viewCount             Int               @default(0)
  metaTitle             String?
  metaDescription       String?

  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  variants              ProductVariant[]
  availabilitySchedule  ProductAvailabilitySchedule[]
  availabilityOverrides ProductAvailabilityOverride[]
  bookingSlots          ProductBookingSlot[]
  bookings              ProductBooking[]
  digitalDownloads      DigitalDownload[]
  cartItems             ProductCartItem[]
  orderItems            OrderItem[]

  @@index([storeId])
  @@index([isPublished])
}

model ProductCartItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("product_cart_items")
}

model ProductVariant {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  name        String
  sku         String?
  price       Float?
  stock       Int?
  images      String[]
  attributes  Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([productId])
}

model ProductAvailabilitySchedule {
  id                  String    @id @default(cuid())
  productId           String
  product             Product   @relation(fields: [productId], references: [id])
  dayOfWeek           Int
  startTime           String
  endTime             String
  slotDurationMins    Int
  slotBufferMins      Int       @default(0)
  maxBookingsPerSlot  Int       @default(1)
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([productId])
}

model ProductAvailabilityOverride {
  id                String    @id @default(cuid())
  productId         String
  product           Product   @relation(fields: [productId], references: [id])
  date              DateTime
  isBlocked         Boolean   @default(false)
  customStartTime   String?
  customEndTime     String?
  reason            String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([productId, date])
}

model ProductBookingSlot {
  id               String           @id @default(cuid())
  productId        String
  product          Product          @relation(fields: [productId], references: [id])
  date             DateTime
  startTime        String
  endTime          String
  maxBookings      Int
  currentBookings  Int              @default(0)
  isAvailable      Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  bookings         ProductBooking[]

  @@unique([productId, date, startTime])
  @@index([productId])
  @@index([date])
}

model ProductBooking {
  id                 String              @id @default(cuid())
  productId          String
  product            Product             @relation(fields: [productId], references: [id])
  slotId             String
  slot               ProductBookingSlot  @relation(fields: [slotId], references: [id])
  customerId         String
  bookingDate        DateTime
  startTime          String
  endTime            String
  guestCount         Int                 @default(1)
  totalPrice         Float
  status             BookingStatus       @default(PENDING)
  cancellationReason String?
  cancelledBy        CancelledBy?
  cancelledAt        DateTime?
  vendorNotes        String?
  customerNotes      String?
  reminderSentAt     DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([productId])
  @@index([customerId])
  @@index([slotId])
  @@index([status])
}

model DigitalDownload {
  id                String    @id @default(cuid())
  productId         String
  product           Product   @relation(fields: [productId], references: [id])
  orderId           String
  customerId        String
  downloadCount     Int       @default(0)
  firstDownloadAt   DateTime?
  lastDownloadAt    DateTime?
  expiresAt         DateTime?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([productId])
  @@index([customerId])
  @@index([orderId])
}

model RealEstate {
  id                String                  @id @default(cuid())
  storeId           String
  store             Store                   @relation(fields: [storeId], references: [id])
  title             String
  slug              String                  @unique
  description       String?
  type              RealEstateType
  listingType       RealEstateListingType

  price             Float
  bedrooms          Int?
  bathrooms         Int?
  sizeSqFt          Float?
  lotSize           Float?
  lotSizeUnit       LotSizeUnit?
  yearBuilt         Int?
  floorLevel        Int?
  totalFloors       Int?
  furnished         Boolean?
  parkingSpaces     Int?
  isNewDevelopment  Boolean                 @default(false)

  titleType         TitleType?
  propertyTax       Float?

  tenure            TenureType?
  depositRequired   Float?
  availableFrom     DateTime?

  amenities         String[]
  nearbyAmenities   String[]
  images            String[]

  latitude          Float
  longitude         Float
  address           String
  region            String

