  DRAFT
  PENDING_PAYMENT
  PAID
  PROCESSING
  PARTIALLY_IN_HOUSE
  READY_TO_SHIP
  PACKING_COMPLETE
  SHIPPED
  CUSTOMER_RECEIVED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  APPROVED
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

