# Copy to ".env" for local development:
#   cp .env.example .env
#
# Next.js loads .env automatically (restart `npm run dev` after changes).

# --- Local PostgreSQL (development) ---
# Replace YOUR_MAC_USERNAME with the output of: whoami
# Replace linkwe_dev with your database name if different.
# No password is common for local Homebrew Postgres (same OS user = trusted).
DATABASE_URL="postgresql://YOUR_MAC_USERNAME@localhost:5432/linkwe_dev"

# If you created a dedicated DB user with a password, use:
# DATABASE_URL="postgresql://linkwe:your_password_here@localhost:5432/linkwe_dev"

# --- Production (Supabase) — use on hosting / CI, not for local dev while pooler/direct DB is blocked ---
# DATABASE_URL="postgresql://postgres.[ref]:[password]@[host]:5432/postgres"

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
